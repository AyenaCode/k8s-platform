#!/usr/bin/env bash
# klab — a thin wrapper around `docker compose` for the K8s Lab.
#
# It remembers WHERE the lab is installed (~/.k8s-lab) and runs Compose with the
# right -f / --project-directory, so you never have to `cd` into the folder.
# All the real logic lives in Docker + the installer; this just drives them.
#
#   klab run | stop | restart | status | logs | shell | reset | update
#   klab url | uninstall | clean | version | help
#
# Knobs (env vars):
#   KLAB_HOME   install directory                 (default: ~/.k8s-lab)
#   KLAB_REPO   GitHub repo to update from         (default: AyenaCode/k8s-platform)
#   LAB_REF     git ref to pull files from         (default: main)
set -euo pipefail

HOME_DIR="${KLAB_HOME:-$HOME/.k8s-lab}"
COMPOSE_FILE="${HOME_DIR}/docker-compose.yml"
APP_SERVICE="app"

# Where `update` re-downloads the lab files from (same source as the installer).
REPO="${KLAB_REPO:-AyenaCode/k8s-platform}"
REF="${LAB_REF:-main}"
RAW="https://raw.githubusercontent.com/${REPO}/${REF}"

# Pretty output (no-op if not a TTY).
if [ -t 1 ]; then B=$'\033[1m'; G=$'\033[32m'; Y=$'\033[33m'; R=$'\033[31m'; N=$'\033[0m'; else B=; G=; Y=; R=; N=; fi
ok()   { printf '%s\n' "${G}✓${N} $*"; }
warn() { printf '%s\n' "${Y}!${N} $*" >&2; }
die()  { printf '%s\n' "${R}✗${N} $*" >&2; exit 1; }

# Pick the available Compose command (plugin or legacy binary).
if docker compose version >/dev/null 2>&1; then
  COMPOSE=(docker compose)
elif command -v docker-compose >/dev/null 2>&1; then
  COMPOSE=(docker-compose)
else
  die "Docker Compose is missing. Install Docker Desktop or the compose plugin."
fi

# Run Compose against the lab, from anywhere on disk.
dc() { "${COMPOSE[@]}" -f "$COMPOSE_FILE" --project-directory "$HOME_DIR" "$@"; }

# Download a repo file into the install dir. Args: <repo path> <dest in HOME_DIR>
fetch() { curl -fsSL "${RAW}/$1" -o "${HOME_DIR}/$2" || die "Could not download $1 (ref: ${REF})."; }

# Single source of truth for the lab's files. Both the installer (via the hidden
# `internal-sync` command) and `klab update` call this, so the list lives in one
# place. Leaves .env (the user's ports) untouched.
sync_files() {
  command -v curl >/dev/null 2>&1 || die "curl is required to download the lab files."
  mkdir -p "${HOME_DIR}/docker"
  fetch "docker-compose.release.yml" "docker-compose.yml"
  fetch "docker/registries.yaml"     "docker/registries.yaml"
  fetch "docker/warm-cache.sh"       "docker/warm-cache.sh"
  fetch "release-readme.md"          "README.md"
  # Self-update klab safely: download to a temp file, then atomically replace.
  # Never `curl -o` the script we're currently running — that corrupts it.
  curl -fsSL "${RAW}/cli/klab" -o "${HOME_DIR}/klab.new" || die "Could not download cli/klab (ref: ${REF})."
  chmod +x "${HOME_DIR}/klab.new"
  mv -f "${HOME_DIR}/klab.new" "${HOME_DIR}/klab"
}

# Read the host app port the installer persisted, default 8088.
lab_url() {
  local port=8088
  if [ -f "${HOME_DIR}/.env" ]; then
    port="$(grep -E '^LAB_PORT=' "${HOME_DIR}/.env" 2>/dev/null | cut -d= -f2 || true)"
    [ -n "$port" ] || port=8088
  fi
  printf 'http://localhost:%s' "$port"
}

need_install() {
  [ -f "$COMPOSE_FILE" ] || die "Lab is not installed at ${HOME_DIR}.
  Install it:  curl -fsSL https://raw.githubusercontent.com/AyenaCode/k8s-platform/main/install.sh | bash"
}

# Seconds to wait before opening the browser, so the page is more likely to find
# the app already answering. Override with KLAB_BROWSER_DELAY (0 = open at once).
BROWSER_DELAY="${KLAB_BROWSER_DELAY:-6}"

open_browser() {
  local url; url="$(lab_url)"
  # Run in the BACKGROUND: the caller (e.g. `run`) goes straight to the
  # foreground `dc up` that starts the stack, while we wait the head-start here.
  # This is a fixed delay on purpose — NOT a health poll / watcher.
  (
    sleep "$BROWSER_DELAY"
    if   command -v open     >/dev/null 2>&1; then open "$url"     >/dev/null 2>&1 || true
    elif command -v xdg-open >/dev/null 2>&1; then xdg-open "$url" >/dev/null 2>&1 || true
    fi
  ) >/dev/null 2>&1 &
}

# Remove the klab symlink from wherever the installer put it on the PATH.
remove_cli_link() {
  local dir removed=0
  for dir in /usr/local/bin "$HOME/.local/bin"; do
    if [ -L "$dir/klab" ]; then
      rm -f "$dir/klab" 2>/dev/null && removed=1 || \
        { command -v sudo >/dev/null 2>&1 && sudo rm -f "$dir/klab" 2>/dev/null && removed=1; }
    fi
  done
  [ "$removed" -eq 1 ] && ok "Removed the 'klab' command from your PATH."
}

usage() {
  cat <<EOF
${B}klab${N} — manage your K8s Lab from anywhere (install dir: ${HOME_DIR})

${B}Usage:${N}  klab <command>

${B}Commands:${N}
  run, up        Start the lab in this terminal (logs stream, Ctrl-C stops all).
                 Add -d to run in the background instead.
  stop           Stop the lab (keeps your progress + cluster data)
  restart        Stop, then start again in this terminal
  status, ps     Show service status
  logs           Tail the app logs (Ctrl-C to quit)
  shell          Open a shell inside the lab container
  reset          Wipe the scratch cluster state (keeps the install)
  update         Pull the latest image and recreate the lab
  url            Print the lab URL
  uninstall, rm  Stop and DELETE the lab's data (containers + volumes)
  clean          FULL cleanup of your PC: removes containers, volumes, all of
                 the lab's Docker images, the install dir, and the klab command
  version        Show the running app image
  help           Show this help (also: klab -h, klab --help)
EOF
}

cmd="${1:-help}"; [ $# -gt 0 ] && shift || true

case "$cmd" in
  run|up|start)
    need_install
    if [ "${1:-}" = "-d" ] || [ "${1:-}" = "--detach" ]; then
      dc up -d
      ok "Lab is starting in the background. Open: ${B}$(lab_url)${N}"
      open_browser
    else
      # Foreground: logs stream here and Ctrl-C stops the whole stack. No daemon.
      printf '%s\n' "Starting the lab in this terminal — logs stream below."
      printf '%s\n' "Open in your browser: ${B}$(lab_url)${N}  (ready ~30s on first boot)"
      printf '%s\n' "Press ${B}Ctrl-C${N} to stop everything. Start again with: klab run"
      open_browser
      dc up
    fi
    ;;
  stop|down)
    need_install; dc stop; ok "Lab stopped (data kept). Start again: klab run"
    ;;
  restart)
    need_install
    dc stop
    printf '%s\n' "Restarting in this terminal — Ctrl-C stops everything. URL: ${B}$(lab_url)${N}"
    open_browser
    dc up
    ;;
  status|ps)
    need_install; dc ps
    ;;
  logs)
    need_install; dc logs -f "$APP_SERVICE"
    ;;
  shell|sh|exec)
    need_install; dc exec "$APP_SERVICE" bash
    ;;
  reset)
    need_install; dc exec "$APP_SERVICE" bash /app/content/reset.sh; ok "Scratch cluster state wiped."
    ;;
  update|upgrade)
    need_install
    # Re-download the release files so topology changes (new services, ports,
    # image refs) land too — not just a new app image. Also self-updates klab.
    printf '%s\n' "Re-downloading the latest lab files (ref: ${REF})…"
    sync_files
    ok "Lab files updated."
    dc pull
    ok "Pulled the latest image."
    # Drop the OLD containers before starting, or `up` reuses the existing
    # container on an unchanged tag (latest) and the freshly pulled image never
    # takes effect — you keep running yesterday's content. `down` (NO -v) removes
    # containers + the network only; the named volumes (pgdata = progress,
    # k3s-data = cluster, registry-cache) survive, so this is NOT `klab rm`.
    dc down
    ok "Update ready. Old containers removed (progress + cluster data kept)."
    printf '%s\n' "Start the new version when you want:  ${B}klab run${N}"
    ;;
  internal-sync)
    # Hidden command used by install.sh to download the lab files after it has
    # bootstrapped klab. Same file list as `update`, no Compose action.
    sync_files
    ;;
  url)
    lab_url; echo
    ;;
  uninstall|rm|destroy)
    need_install
    dc down -v
    ok "Lab containers and data removed (images + files kept)."
    printf '%s\n' "  To wipe everything off your PC instead, run: ${B}klab clean${N}"
    ;;
  clean|nuke|purge)
    # Full cleanup: nothing about the lab should be left on the machine.
    if [ "${1:-}" != "-y" ] && [ "${1:-}" != "--yes" ]; then
      printf '%s' "This deletes the lab's containers, volumes, ALL its Docker images, ${HOME_DIR}, and the klab command. Continue? [y/N] "
      read -r reply || reply=n
      case "$reply" in y|Y|yes|YES) ;; *) die "Cancelled." ;; esac
    fi
    if [ -f "$COMPOSE_FILE" ]; then
      # --rmi all drops every image used by the stack (app, k3s, postgres,
      # registry, crane); -v drops the volumes; --remove-orphans cleans strays.
      dc down -v --rmi all --remove-orphans || warn "Compose teardown reported errors; continuing."
    else
      warn "No install found at ${HOME_DIR}; just cleaning up leftovers."
    fi
    rm -rf "$HOME_DIR" && ok "Removed ${HOME_DIR}."
    remove_cli_link
    ok "Done. The K8s Lab is fully removed from this machine."
    ;;
  version|--version|-v)
    need_install
    dc config --images 2>/dev/null | grep -E 'k8s-platform' || dc ps "$APP_SERVICE"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    warn "Unknown command: ${cmd}"
    usage
    exit 1
    ;;
esac
