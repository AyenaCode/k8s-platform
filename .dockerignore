# Keep the build context small and reproducible.
.git
.claude

# Frontend: rebuilt inside the image from lockfile.
frontend/node_modules
frontend/dist

# Backend: built inside the image.
backend/bin

# Docs / local files. Anchor *.md to the repo root so lesson content under
# content/lessons/**/*.md is NOT excluded from the build context.
/*.md
*.log
*.local.*
.env
