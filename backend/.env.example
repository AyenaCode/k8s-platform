# Copy to .env and adjust. All values have sane defaults; nothing here is required.

# HTTP bind address.
ADDR=:8080

# Content tier (markdown + scripts). Defaults resolve to the repo root.
CONTENT_ROOT=..
# COURSES_DIR=../courses
# EXERCISES_DIR=../exercices

# Built frontend SPA. Leave empty for API-only mode (use Vite dev server instead).
STATIC_DIR=../frontend/dist

# Data tier. Leave empty for the in-memory store (no Postgres needed).
# DATABASE_URL=postgres://k8s:k8s@localhost:5432/k8s_platform?sslmode=disable

# Shell spawned by the interactive PTY terminal.
PTY_SHELL=/bin/bash
